# Copy to .env and fill in — OR just paste keys into the app's Settings page,
# which is BYOK (kept in your browser, sent per-request, never written here).
# PromptLab runs fully offline without any keys (a deterministic StubLLM stands
# in for any provider you haven't configured), so the UI always works.

# --- Provider API keys (all optional; mainly for funding the judge model,
#     or a personal single-user self-host) ---
PROMPTLAB_OPENAI_API_KEY=
PROMPTLAB_ANTHROPIC_API_KEY=
PROMPTLAB_GEMINI_API_KEY=
PROMPTLAB_GROQ_API_KEY=
# OpenRouter is a single key that unlocks many models (OpenAI/Claude/Gemini/…):
PROMPTLAB_OPENROUTER_API_KEY=

# --- Judge (the fixed, neutral referee that scores every answer) ---
# Keep it constant across an experiment so cross-model comparison is fair. It
# needs its provider's key configured; otherwise judging falls back to a neutral
# stub score.
PROMPTLAB_JUDGE_PROVIDER=groq
PROMPTLAB_JUDGE_MODEL=llama-3.3-70b-versatile

# --- Key storage ---
# Off by default: a deployed instance can't persist a pasted key to server-side
# disk at all. Only turn this on for a personal, single-user local self-host.
# Never enable it on a deployment other people can reach.
PROMPTLAB_ALLOW_STORED_KEYS=false

# --- API server ---
# Port 8100 avoids the common 8000 default used by other local dev servers.
PROMPTLAB_API_HOST=127.0.0.1
PROMPTLAB_API_PORT=8100
# JSON array of browser origins allowed to call the API (the Vite dev server on 5174).
PROMPTLAB_ALLOWED_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174"]
