# Copy to .env and fill in. PromptLab runs fully offline without any of these
# (it falls back to a deterministic StubLLM so every screen still works), but
# real completions and the LLM-as-judge grader need at least one provider key.

# --- Default LLM provider (OpenAI-compatible). Groq's free tier works great. ---
# For Groq:
#   PROMPTLAB_LLM_BASE_URL=https://api.groq.com/openai/v1
# For OpenAI:
#   PROMPTLAB_LLM_BASE_URL=https://api.openai.com/v1
PROMPTLAB_LLM_API_KEY=
PROMPTLAB_LLM_BASE_URL=https://api.groq.com/openai/v1

# --- Optional per-provider keys ---
# Set any of these to enable that provider's models in the dropdown at once,
# without swapping PROMPTLAB_LLM_API_KEY between runs. Each provider is reached
# through its OpenAI-compatible endpoint (see catalog.py).
PROMPTLAB_OPENAI_API_KEY=
PROMPTLAB_GROQ_API_KEY=
PROMPTLAB_GEMINI_API_KEY=

# --- Judge ---
# The fixed model used to score candidate answers. Keep it constant while you
# vary the prompts under test.
PROMPTLAB_JUDGE_MODEL=llama-3.3-70b-versatile

# --- API server (used by `promptlab serve`) ---
PROMPTLAB_API_HOST=127.0.0.1
PROMPTLAB_API_PORT=8000
# JSON array of browser origins allowed to call the API (the Vite dev server).
PROMPTLAB_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
